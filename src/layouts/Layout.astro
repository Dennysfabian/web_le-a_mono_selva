---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Leña al Mono — Auténtica Parrilla Ecuatoriana | Barcelona",
  description = "Sabores ecuatorianos a la leña en Barcelona. Carnes, mariscos, ceviche y tradición. Reserva tu mesa en L'Hospitalet de Llobregat.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background-color: #0F0D0B;
    color: #F0EBE1;
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
  }

  .font-display { font-family: 'Playfair Display', serif; }

  /* ── Scroll Reveal ── */
  .reveal {
    opacity: 0;
    transform: translateY(48px);
    transition: opacity 0.9s cubic-bezier(.22,1,.36,1), transform 0.9s cubic-bezier(.22,1,.36,1);
  }
  .reveal.visible { opacity: 1; transform: none; }
  .d1 { transition-delay: 0.1s; }
  .d2 { transition-delay: 0.2s; }
  .d3 { transition-delay: 0.3s; }
  .d4 { transition-delay: 0.4s; }
  .d5 { transition-delay: 0.5s; }

  /* ── Buttons ── */
  @keyframes glowPulse {
    0%, 100% { box-shadow: 0 0 18px rgba(200,132,26,0.5); }
    50%       { box-shadow: 0 0 45px rgba(200,132,26,0.95), 0 0 90px rgba(200,132,26,0.3); }
  }
  .btn-ember {
    display: inline-block;
    background: linear-gradient(135deg, #C8841A, #E8A030);
    color: #0F0D0B;
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    padding: 0.9rem 2.2rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: transform 0.3s ease;
    animation: glowPulse 3s ease-in-out infinite;
  }
  .btn-ember:hover { transform: scale(1.05); }

  .btn-outline {
    display: inline-block;
    background: transparent;
    color: #F0EBE1;
    border: 1px solid rgba(240,235,225,0.35);
    font-size: 0.72rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    padding: 0.9rem 2.2rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  .btn-outline:hover { border-color: #C8841A; color: #C8841A; }

  /* ── Divider ── */
  .divider {
    width: 48px; height: 2px;
    background: linear-gradient(90deg, #C8841A, transparent);
    margin: 1.2rem 0;
  }
  .divider-center { margin: 1.2rem auto; }

  /* ── Bento Cards ── */
  .bento-card { position: relative; overflow: hidden; }
  .bento-card img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.65s cubic-bezier(.25,.46,.45,.94);
  }
  .bento-card:hover img { transform: scale(1.07); }
  .bento-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(15,13,11,0.88) 0%, rgba(15,13,11,0.1) 55%, transparent 100%);
  }
  .bento-shine {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(200,132,26,0.12), transparent 60%);
    opacity: 0;
    transition: opacity 0.45s ease;
  }
  .bento-card:hover .bento-shine { opacity: 1; }

  /* ── Service Cards ── */
  .service-card {
    background: #181410;
    border: 1px solid rgba(200,132,26,0.12);
    transition: border-color 0.3s, transform 0.3s;
    overflow: hidden;
  }
  .service-card:hover { border-color: rgba(200,132,26,0.45); transform: translateY(-4px); }

  /* ── Testimonial Cards ── */
  .testi-card {
    background: #181410;
    border: 1px solid rgba(200,132,26,0.1);
    transition: transform 0.35s, border-color 0.35s;
  }
  .testi-card:hover { transform: translateY(-7px); border-color: rgba(200,132,26,0.35); }

  /* ── Section wrapper ── */
  .section-wrap { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
</style>

<script>
  // Scroll Reveal
  const revealEls = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  revealEls.forEach(el => observer.observe(el));

  // Nav solid on scroll
  const nav = document.getElementById('main-nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 80);
    }, { passive: true });
  }
</script>
