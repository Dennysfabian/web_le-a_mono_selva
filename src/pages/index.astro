---
// index.astro — Leña al Mono Landing Page
// NOTA DEV: Mover las imágenes de /imagenes/ a /public/imagenes/ para que Astro las sirva correctamente.
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout>

  <!-- ── NAV ── -->
  <nav id="main-nav" style="position:fixed; top:0; left:0; right:0; z-index:100; padding:1.4rem 2.5rem; display:flex; justify-content:space-between; align-items:center; background:linear-gradient(to bottom,rgba(15,13,11,0.92),transparent); transition:background 0.4s, backdrop-filter 0.4s;">
    <a href="#inicio" style="text-decoration:none;">
      <span class="font-display" style="font-size:1.4rem; font-weight:900; color:#F0EBE1; letter-spacing:0.04em;">
        Leña <em style="color:#C8841A;">al Mono</em>
      </span>
    </a>
    <div style="display:flex; gap:2rem; align-items:center;">
      <a href="#especialidades" style="color:rgba(240,235,225,0.65); text-decoration:none; font-size:0.72rem; letter-spacing:0.12em; text-transform:uppercase; transition:color 0.3s;">Carta</a>
      <a href="#servicios" style="color:rgba(240,235,225,0.65); text-decoration:none; font-size:0.72rem; letter-spacing:0.12em; text-transform:uppercase; transition:color 0.3s;">Servicios</a>
      <a href="#contacto" style="color:rgba(240,235,225,0.65); text-decoration:none; font-size:0.72rem; letter-spacing:0.12em; text-transform:uppercase; transition:color 0.3s;">Horario</a>
      <a href="https://book.squareup.com/appointments/hcx6emfmutkvpv/location/LMCFB6GK0PKF1"
         target="_blank" rel="noopener"
         class="btn-ember" style="padding:0.55rem 1.4rem; font-size:0.68rem;">
        Reservar
      </a>
    </div>
  </nav>

  <!-- ── HERO + MARQUEE ── -->
  <Hero />

  <!-- ════════════════════════════════════════════════════════
       NUESTRA ESENCIA
  ════════════════════════════════════════════════════════ -->
  <section id="esencia" style="padding:8rem 0;">
    <div class="section-wrap">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center;">

        <!-- Imagen -->
        <div class="reveal" style="position:relative;">
          <!--
            NOTA DEV: interior_dos.webp
            Vista panorámica del restaurante con decoración 100% ecuatoriana:
            hamaca, banderas de Ecuador, escalera de hierro con luces Edison,
            paredes con listones de bambú. Ambiente cálido y cultural.
            Entrada: fade-in desde la izquierda (añadir translateX(-40px) inicial si se desea).
          -->
          <img
            src="/imagenes/interior_dos.webp"
            alt="Interior de Leña al Mono con decoración ecuatoriana"
            style="width:100%; height:580px; object-fit:cover; display:block;"
          />
          <!-- Marco offset ámbar -->
          <div style="position:absolute; bottom:-14px; right:-14px; width:calc(100% - 1.5rem); height:calc(100% - 1.5rem); border:1px solid rgba(200,132,26,0.28); pointer-events:none;"></div>
          <!-- Badge flotante -->
          <div style="position:absolute; top:2rem; left:-1.5rem; background:#C8841A; color:#0F0D0B; padding:1rem 1.2rem; text-align:center; line-height:1.15;">
            <p class="font-display" style="font-weight:900; font-size:2.1rem;">+500</p>
            <p style="font-size:0.6rem; letter-spacing:0.18em; text-transform:uppercase; font-weight:600; margin-top:0.15rem;">Reseñas ⭐</p>
          </div>
        </div>

        <!-- Texto -->
        <div>
          <p class="reveal font-display" style="font-style:italic; color:#C8841A; font-size:0.82rem; letter-spacing:0.22em; text-transform:uppercase;">Nuestra Historia</p>
          <div class="reveal d1 divider"></div>
          <h2 class="reveal d2 font-display" style="font-weight:900; font-size:clamp(2.5rem,4.5vw,3.75rem); line-height:1.05; color:#F0EBE1; margin-bottom:1.75rem;">
            Cocina que<br/>nace del<br/><em style="color:#C8841A;">fuego</em>
          </h2>
          <p class="reveal d3" style="color:rgba(240,235,225,0.72); line-height:1.9; font-size:1rem; margin-bottom:1.4rem;">
            En <strong style="color:#F0EBE1;">Leña al Mono</strong> creemos en la cocina que nace de lo simple: fuego, buenos ingredientes y tradición. Inspirados en los sabores de Ecuador, hemos creado en Barcelona un espacio donde cada plato celebra nuestra cultura.
          </p>
          <p class="reveal d4" style="color:rgba(240,235,225,0.72); line-height:1.9; font-size:1rem; margin-bottom:2.5rem;">
            Cada mordisco es un viaje. Un plato que sabe a hogar, a familia, a domingo. Una experiencia que quienes descubren la gastronomía ecuatoriana por primera vez — nunca olvidan.
          </p>
          <a href="https://book.squareup.com/appointments/hcx6emfmutkvpv/location/LMCFB6GK0PKF1"
             target="_blank" rel="noopener"
             class="reveal d5 btn-ember">
            Reservar Mesa
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       ESPECIALIDADES — BENTO GRID
  ════════════════════════════════════════════════════════ -->
  <section id="especialidades" style="padding:4rem 0 8rem; background:#0D0B09;">
    <div class="section-wrap">

      <div style="text-align:center; margin-bottom:3.5rem;">
        <p class="reveal font-display" style="font-style:italic; color:#C8841A; font-size:0.82rem; letter-spacing:0.22em; text-transform:uppercase;">Del Ecuador a tu mesa</p>
        <div class="reveal d1 divider divider-center"></div>
        <h2 class="reveal d2 font-display" style="font-weight:900; font-size:clamp(2.5rem,5vw,4rem); color:#F0EBE1; line-height:1.05;">
          Nuestras<br/><em style="color:#C8841A;">Especialidades</em>
        </h2>
      </div>

      <div class="reveal d2 bento-grid">

        <!--
          B1: interior_uno.webp — ambiente íntimo con vinoteca, plantas, escalera de mármol.
          Iluminación dorada de noche. Posición: columna 1, toda la altura.
        -->
        <div class="bento-card b1">
          <img src="/imagenes/interior_uno.webp" alt="Ambiente íntimo de Leña al Mono" />
          <div class="bento-overlay"></div>
          <div class="bento-shine"></div>
          <div style="position:absolute; bottom:1.75rem; left:1.75rem; z-index:2;">
            <p style="color:rgba(240,235,225,0.55); font-size:0.68rem; letter-spacing:0.18em; text-transform:uppercase; margin-bottom:0.3rem;">Ambiente</p>
            <p class="font-display" style="font-weight:700; color:#F0EBE1; font-size:1.4rem; line-height:1.2;">El Rincón<br/>Perfecto</p>
          </div>
        </div>

        <!--
          B2: mariscada_parrilla.webp — parrillada de mariscos completa: cangrejo, mejillones,
          gambas, patacones, ensalada de aguacate fresca. La foto más impactante del set.
          Posición: columnas 2-3, fila superior.
        -->
        <div class="bento-card b2">
          <img src="/imagenes/mariscada_parrilla.webp" alt="Mariscada a la parrilla — Leña al Mono" />
          <div class="bento-overlay"></div>
          <div class="bento-shine"></div>
          <div style="position:absolute; bottom:1.6rem; left:1.75rem; z-index:2;">
            <p style="color:#C8841A; font-size:0.68rem; letter-spacing:0.18em; text-transform:uppercase; margin-bottom:0.3rem;">⭐ Estrella de la Casa</p>
            <p class="font-display" style="font-weight:700; color:#F0EBE1; font-size:1.9rem; line-height:1.1;">Mariscada a la Parrilla</p>
          </div>
        </div>

        <!--
          B3: plato_ceviche.webp — ceviche de camarones ecuatoriano en plato blanco:
          gambas sobre caldo naranja vibrante, patacones crujientes, aguacate en abanico.
          Posición: columna 2, fila inferior.
        -->
        <div class="bento-card b3">
          <img src="/imagenes/plato_ceviche.webp" alt="Ceviche de camarones" />
          <div class="bento-overlay"></div>
          <div class="bento-shine"></div>
          <div style="position:absolute; bottom:1.2rem; left:1.25rem; z-index:2;">
            <p class="font-display" style="font-weight:700; color:#F0EBE1; font-size:1.1rem; line-height:1.2;">Ceviche de<br/>Camarones</p>
          </div>
        </div>

        <!--
          B4: plato_guatita.webp — guatita ecuatoriana tradicional: callos en salsa
          amarilla con maní, arroz blanco, aguacate y plátano maduro frito.
          Posición: columna 3, fila inferior.
        -->
        <div class="bento-card b4">
          <img src="/imagenes/plato_guatita.webp" alt="Guatita tradicional ecuatoriana" />
          <div class="bento-overlay"></div>
          <div class="bento-shine"></div>
          <div style="position:absolute; bottom:1.2rem; left:1.25rem; z-index:2;">
            <p class="font-display" style="font-weight:700; color:#F0EBE1; font-size:1.1rem; line-height:1.2;">Guatita<br/>Tradicional</p>
          </div>
        </div>

      </div>

      <div style="text-align:center; margin-top:2.75rem;">
        <a href="https://get-qr.com/es/content/c7Nj1A" target="_blank" rel="noopener" class="btn-outline">
          Ver Carta Completa
        </a>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       SERVICIOS
  ════════════════════════════════════════════════════════ -->
  <section id="servicios" style="padding:8rem 0;">
    <div class="section-wrap">

      <div style="margin-bottom:3.5rem;">
        <p class="reveal font-display" style="font-style:italic; color:#C8841A; font-size:0.82rem; letter-spacing:0.22em; text-transform:uppercase;">Más que un restaurante</p>
        <div class="reveal d1 divider"></div>
        <h2 class="reveal d2 font-display" style="font-weight:900; font-size:clamp(2.5rem,4vw,3.5rem); color:#F0EBE1; line-height:1.05;">
          Una experiencia<br/><em style="color:#C8841A;">completa</em>
        </h2>
      </div>

      <div class="service-grid">

        <!--
          Chill Out: interior_tres_zona_cockteles.webp
          Terraza luminosa con sillas blancas, cojines mostaza, palmeras, techo de cristal y luces de hada.
          Efecto imagen de fondo absoluta con overlay degradado al fondo.
        -->
        <div class="reveal service-card sc-chillout" style="position:relative;">
          <img src="/imagenes/interior_tres_zona_cockteles.webp"
               alt="Zona Chill Out y terraza de Leña al Mono"
               style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover;" />
          <div style="position:absolute; inset:0; background:linear-gradient(to top,rgba(15,13,11,0.92) 0%,rgba(15,13,11,0.35) 65%,transparent 100%);"></div>
          <div style="position:absolute; bottom:0; left:0; right:0; padding:2.5rem;">
            <p style="color:#C8841A; font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; margin-bottom:0.5rem;">Terraza al aire libre</p>
            <h3 class="font-display" style="font-weight:700; font-size:2.1rem; color:#F0EBE1; margin-bottom:0.85rem; line-height:1.15;">Zona Chill Out</h3>
            <p style="color:rgba(240,235,225,0.75); line-height:1.75; font-size:0.95rem; max-width:400px;">
              Disfruta de nuestra terraza pensada para relajarte y compartir. Un ambiente perfecto para desconectar bajo la luz del día o las estrellas.
            </p>
          </div>
        </div>

        <!-- Eventos -->
        <div class="reveal d2 service-card sc-eventos" style="padding:2.25rem; display:flex; flex-direction:column;">
          <div style="width:46px; height:46px; background:rgba(200,132,26,0.12); display:flex; align-items:center; justify-content:center; font-size:1.4rem; margin-bottom:1.5rem;">🔥</div>
          <h3 class="font-display" style="font-weight:700; font-size:1.45rem; color:#F0EBE1; margin-bottom:0.85rem; line-height:1.2;">Eventos<br/>Especiales</h3>
          <p style="color:rgba(240,235,225,0.68); line-height:1.75; font-size:0.92rem; flex:1;">
            Cumpleaños, reuniones privadas o eventos corporativos. Creamos experiencias únicas donde la gastronomía y el ambiente son los protagonistas.
          </p>
          <a href="https://book.squareup.com/appointments/hcx6emfmutkvpv/location/LMCFB6GK0PKF1"
             target="_blank" rel="noopener"
             style="color:#C8841A; font-size:0.72rem; letter-spacing:0.12em; text-transform:uppercase; text-decoration:none; margin-top:1.75rem; display:inline-flex; align-items:center; gap:0.4rem;">
            Solicitar Evento →
          </a>
        </div>

        <!-- Catering -->
        <div class="reveal d3 service-card sc-catering" style="padding:2.25rem; display:flex; flex-direction:column;">
          <div style="width:46px; height:46px; background:rgba(200,132,26,0.12); display:flex; align-items:center; justify-content:center; font-size:1.4rem; margin-bottom:1.5rem;">🍽️</div>
          <h3 class="font-display" style="font-weight:700; font-size:1.45rem; color:#F0EBE1; margin-bottom:0.85rem; line-height:1.2;">Catering<br/>Personalizado</h3>
          <p style="color:rgba(240,235,225,0.68); line-height:1.75; font-size:0.92rem; flex:1;">
            Llevamos lo mejor de nuestra cocina a donde lo necesites. Auténtico sabor ecuatoriano a la leña para cualquier tipo de evento.
          </p>
          <a href="#contacto"
             style="color:#C8841A; font-size:0.72rem; letter-spacing:0.12em; text-transform:uppercase; text-decoration:none; margin-top:1.75rem; display:inline-flex; align-items:center; gap:0.4rem;">
            Consultar →
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       TESTIMONIOS
  ════════════════════════════════════════════════════════ -->
  <section style="padding:4rem 0 8rem; background:#0D0B09;">
    <div class="section-wrap">

      <div style="text-align:center; margin-bottom:4rem;">
        <p class="reveal font-display" style="font-style:italic; color:#C8841A; font-size:0.82rem; letter-spacing:0.22em; text-transform:uppercase;">Lo que dicen nuestros clientes</p>
        <div class="reveal d1 divider divider-center"></div>
        <h2 class="reveal d2 font-display" style="font-weight:900; font-size:clamp(2.2rem,4vw,3rem); color:#F0EBE1; line-height:1.1;">
          Palabras que<br/><em style="color:#C8841A;">nos llenan</em>
        </h2>
      </div>

      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; max-width:880px; margin:0 auto;">

        <div class="reveal testi-card" style="padding:2.5rem; position:relative;">
          <div class="font-display" style="position:absolute; top:1.25rem; right:1.75rem; font-size:5.5rem; color:rgba(200,132,26,0.08); line-height:1; font-weight:900; pointer-events:none;">"</div>
          <div style="margin-bottom:1.1rem; font-size:1rem; color:#C8841A; letter-spacing:0.1em;">★★★★★</div>
          <p style="color:rgba(240,235,225,0.85); line-height:1.85; font-style:italic; font-size:0.97rem; margin-bottom:1.75rem;">
            "The smoky grilled meats at Leña al Mono take you straight to Ecuador! The flavors, the atmosphere, the warmth of the staff — absolutely unforgettable."
          </p>
          <div style="display:flex; align-items:center; gap:0.8rem;">
            <div style="width:40px; height:40px; background:linear-gradient(135deg,#C8841A,#E8A030); border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:0.9rem; color:#0F0D0B; flex-shrink:0;">A</div>
            <div>
              <p style="color:#F0EBE1; font-weight:600; font-size:0.88rem;">Ana R.</p>
              <p style="color:rgba(240,235,225,0.42); font-size:0.72rem;">Google Reviews</p>
            </div>
          </div>
        </div>

        <div class="reveal d2 testi-card" style="padding:2.5rem; position:relative;">
          <div class="font-display" style="position:absolute; top:1.25rem; right:1.75rem; font-size:5.5rem; color:rgba(200,132,26,0.08); line-height:1; font-weight:900; pointer-events:none;">"</div>
          <div style="margin-bottom:1.1rem; font-size:1rem; color:#C8841A; letter-spacing:0.1em;">★★★★★</div>
          <p style="color:rgba(240,235,225,0.85); line-height:1.85; font-style:italic; font-size:0.97rem; margin-bottom:1.75rem;">
            "Warm ambiance and authentic flavors make every visit unforgettable. The ceviche and the grilled specialties are a must-try. A real gem in Barcelona."
          </p>
          <div style="display:flex; align-items:center; gap:0.8rem;">
            <div style="width:40px; height:40px; background:linear-gradient(135deg,#2D5A27,#4A8C42); border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:0.9rem; color:#F0EBE1; flex-shrink:0;">L</div>
            <div>
              <p style="color:#F0EBE1; font-weight:600; font-size:0.88rem;">Luis M.</p>
              <p style="color:rgba(240,235,225,0.42); font-size:0.72rem;">Google Reviews</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       HORARIOS & CONTACTO
  ════════════════════════════════════════════════════════ -->
  <section id="contacto" style="padding:8rem 0;">
    <div class="section-wrap">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:start;">

        <div>
          <p class="reveal font-display" style="font-style:italic; color:#C8841A; font-size:0.82rem; letter-spacing:0.22em; text-transform:uppercase;">Ven a visitarnos</p>
          <div class="reveal d1 divider"></div>
          <h2 class="reveal d2 font-display" style="font-weight:900; font-size:clamp(2rem,3.5vw,2.75rem); color:#F0EBE1; line-height:1.1; margin-bottom:2rem;">
            Horario &<br/><em style="color:#C8841A;">Dirección</em>
          </h2>
          <div class="reveal d3" style="margin-bottom:2rem; padding-bottom:2rem; border-bottom:1px solid rgba(240,235,225,0.07);">
            <p style="color:rgba(240,235,225,0.42); font-size:0.65rem; letter-spacing:0.18em; text-transform:uppercase; margin-bottom:0.6rem;">📍 Dirección</p>
            <p style="color:#F0EBE1; font-size:1rem; line-height:1.7;">
              Carrer d'Enric Prat de la Riba, 65<br/>
              08901 L'Hospitalet de Llobregat<br/>
              Barcelona
            </p>
          </div>
          <div class="reveal d4">
            <p style="color:rgba(240,235,225,0.42); font-size:0.65rem; letter-spacing:0.18em; text-transform:uppercase; margin-bottom:1rem;">🕐 Horario</p>
            {[
              ['Miércoles', '12:30–17:00'],
              ['Jueves', '12:30–17:00 · 20:00–23:30'],
              ['Viernes', '12:30–17:00 · 20:00–24:00'],
              ['Sábado', '10:00–24:00'],
              ['Domingo', '10:00–18:00'],
            ].map(([dia, hora]) => (
              <div style="display:flex; justify-content:space-between; padding:0.8rem 0; border-bottom:1px solid rgba(240,235,225,0.06);">
                <span style="color:rgba(240,235,225,0.6); font-size:0.9rem;">{dia}</span>
                <span style="color:#F0EBE1; font-size:0.9rem;">{hora}</span>
              </div>
            ))}
            <div style="display:flex; justify-content:space-between; padding:0.8rem 0;">
              <span style="color:rgba(240,235,225,0.3); font-size:0.9rem;">Lunes & Martes</span>
              <span style="color:rgba(240,235,225,0.3); font-size:0.9rem;">Cerrado</span>
            </div>
          </div>
        </div>

        <div class="reveal d2">
          <div style="position:relative; margin-bottom:2rem; overflow:hidden;">
            <iframe
              src="https://maps.google.com/maps?q=Carrer+d'Enric+Prat+de+la+Riba+65+L'Hospitalet+de+Llobregat+Barcelona&output=embed"
              width="100%" height="290"
              style="border:none; display:block; filter:grayscale(1) invert(0.88) contrast(0.85) sepia(0.25);"
              allowfullscreen loading="lazy"
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
            <div style="position:absolute; inset:0; border:1px solid rgba(200,132,26,0.25); pointer-events:none;"></div>
          </div>
          <div style="background:linear-gradient(135deg,#181410,#1F1A14); border:1px solid rgba(200,132,26,0.18); padding:2.5rem; text-align:center;">
            <p class="font-display" style="font-style:italic; color:#C8841A; font-size:0.82rem; letter-spacing:0.18em; text-transform:uppercase; margin-bottom:0.6rem;">¿Listo para el sabor?</p>
            <h3 class="font-display" style="font-weight:900; font-size:1.8rem; color:#F0EBE1; margin-bottom:0.7rem; line-height:1.2;">
              Haz tu Reserva <em style="color:#C8841A;">Ahora</em>
            </h3>
            <p style="color:rgba(240,235,225,0.6); font-size:0.9rem; margin-bottom:1.75rem; line-height:1.65;">
              Asegura tu mesa y prepárate para<br/>un viaje de sabores que no olvidarás.
            </p>
            <a href="https://book.squareup.com/appointments/hcx6emfmutkvpv/location/LMCFB6GK0PKF1"
               target="_blank" rel="noopener"
               class="btn-ember"
               style="width:100%; display:block; text-align:center;">
              Reservar Mesa Online
            </a>
            <p style="color:rgba(240,235,225,0.3); font-size:0.72rem; margin-top:1rem;">También puedes contactarnos por Instagram</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       FOOTER
  ════════════════════════════════════════════════════════ -->
  <footer style="background:#0A0806; border-top:1px solid rgba(200,132,26,0.12); padding:3rem 2.5rem;">
    <div style="max-width:1200px; margin:0 auto;">
      <div style="display:flex; flex-wrap:wrap; justify-content:space-between; align-items:center; gap:2rem; margin-bottom:2rem;">
        <div>
          <p class="font-display" style="font-weight:900; font-size:1.65rem; color:#F0EBE1; margin-bottom:0.2rem;">
            Leña <em style="color:#C8841A;">al Mono</em>
          </p>
          <p style="color:rgba(240,235,225,0.35); font-size:0.75rem; letter-spacing:0.06em;">Parte de Super Tropical Group</p>
