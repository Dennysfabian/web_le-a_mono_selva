---
// Hero.astro — Leña al Mono
// NOTA DEV: La imagen de fondo (mariscada_parrilla.webp) debe estar en /public/imagenes/
// Efecto parallax activo en desktop, desactivado en móvil por rendimiento.
---

<style>
  .hero-bg {
    background-image: url('/imagenes/mariscada_parrilla.webp');
    background-size: cover;
    background-position: center 30%;
    background-attachment: fixed;
    min-height: 100vh;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  @media (max-width: 768px) {
    /* iOS/Safari no soporta background-attachment: fixed en elementos con overflow */
    .hero-bg { background-attachment: scroll; }
  }

  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(
      160deg,
      rgba(15,13,11,0.90) 0%,
      rgba(15,13,11,0.55) 45%,
      rgba(15,13,11,0.80) 100%
    );
  }

  /* ── Scroll indicator ── */
  @keyframes scrollDrop {
    0%   { transform: translateY(0); opacity: 1; }
    100% { transform: translateY(14px); opacity: 0; }
  }
  .scroll-dot { animation: scrollDrop 1.9s ease-in-out infinite; }

  /* ── Marquee ── */
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  .marquee-track {
    animation: marquee 22s linear infinite;
    white-space: nowrap;
    display: inline-flex;
    gap: 3.5rem;
  }
</style>

<!-- ── HERO SECTION ── -->
<!--
  NOTA DEV:
  · Imagen de fondo: mariscada_parrilla.webp (parrillada de mariscos: cangrejo, mejillones, gambas + patacones + ensalada aguacate)
  · Es la foto más impactante del set. Efecto parallax con dark overlay cálido.
  · Los elementos de texto entran con stagger (delay via JS en DOMContentLoaded).
-->
<section id="inicio" class="hero-bg">
  <div class="hero-overlay"></div>

  <div style="position:relative; z-index:10; text-align:center; padding:0 1.5rem; max-width:820px; margin:0 auto;">

    <!-- Eyebrow tag -->
    <p class="reveal font-display"
       style="font-style:italic; color:#C8841A; font-size:1rem; letter-spacing:0.22em; text-transform:uppercase; margin-bottom:1.75rem;">
      L'Hospitalet de Llobregat · Barcelona
    </p>

    <!-- Headline principal -->
    <h1 class="reveal d1 font-display"
        style="font-weight:900; font-size:clamp(4rem,13vw,9.5rem); line-height:0.88; color:#F0EBE1; margin-bottom:1.5rem;">
      Leña<br/>
      <em style="color:#C8841A;">al Mono</em>
    </h1>

    <!-- Tagline -->
    <p class="reveal d2 font-display"
       style="font-style:italic; font-size:clamp(1.1rem,2.5vw,1.5rem); color:rgba(240,235,225,0.8); line-height:1.65; margin-bottom:2.75rem; max-width:480px; margin-left:auto; margin-right:auto;">
      Fuego, tradición y sabores del Ecuador<br/>
      que despiertan el alma.
    </p>

    <!-- CTAs -->
    <div class="reveal d3" style="display:flex; flex-wrap:wrap; gap:1rem; justify-content:center;">
      <a href="https://book.squareup.com/appointments/hcx6emfmutkvpv/location/LMCFB6GK0PKF1"
         target="_blank" rel="noopener"
         class="btn-ember">
        Reservar Mesa
      </a>
      <a href="https://get-qr.com/es/content/c7Nj1A"
         target="_blank" rel="noopener"
         class="btn-outline">
        Ver Carta
      </a>
    </div>
  </div>

  <!-- Scroll indicator animado -->
  <div style="position:absolute; bottom:2.5rem; left:50%; transform:translateX(-50%); text-align:center; display:flex; flex-direction:column; align-items:center; gap:0.7rem;">
    <span style="font-size:0.6rem; letter-spacing:0.22em; text-transform:uppercase; color:rgba(240,235,225,0.38);">Descubre</span>
    <div style="width:1px; height:48px; background:linear-gradient(to bottom,#C8841A,transparent); position:relative; overflow:hidden;">
      <div class="scroll-dot" style="width:4px; height:4px; background:#C8841A; border-radius:50%; position:absolute; top:0; left:-1.5px;"></div>
    </div>
  </div>
</section>

<!-- ── MARQUEE STRIP (amber) ── -->
<div style="background:#C8841A; padding:0.85rem 0; overflow:hidden;">
  <div class="marquee-track">
    <span class="font-display" style="font-style:italic; color:#0F0D0B; font-size:1.05rem;">Cocina Ecuatoriana</span>
    <span style="color:rgba(15,13,11,0.35);">✦</span>
    <span class="font-display" style="font-style:italic; color:#0F0D0B; font-size:1.05rem;">A la Leña</span>
    <span style="color:rgba(15,13,11,0.35);">✦</span>
    <span class="font-display" style="font-style:italic; color:#0F0D0B; font-size:1.05rem;">Sabores Auténticos</span>
    <span style="color:rgba(15,13,11,0.35);">✦</span>
    <span class="font-display" style="font-style:italic; color:#0F0D0B; font-size:1.05rem;">Parrilla & Mariscos</span>
    <span style="color:rgba(15,13,11,0.35);">✦</span>
    <span class="font-display" style="font-style:italic; color:#0F0D0B; font-size:1.05rem;">Eventos & Catering</span>
    <span style="color:rgba(15,13,11,0.35);">✦</span>
    <!-- Duplicate for seamless loop -->
    <span class="font-display" style="font-style:italic; color:#0F0D0B; font-size:1.05rem;">Cocina Ecuatoriana</span>
    <span style="color:rgba(15,13,11,0.35);">✦</span>
    <span class="font-display" style="font-style:italic; color:#0F0D0B; font-size:1.05rem;">A la Leña</span>
    <span style="color:rgba(15,13,11,0.35);">✦</span>
    <span class="font-display" style="font-style:italic; color:#0F0D0B; font-size:1.05rem;">Sabores Auténticos</span>
    <span style="color:rgba(15,13,11,0.35);">✦</span>
    <span class="font-display" style="font-style:italic; color:#0F0D0B; font-size:1.05rem;">Parrilla & Mariscos</span>
    <span style="color:rgba(15,13,11,0.35);">✦</span>
    <span class="font-display" style="font-style:italic; color:#0F0D0B; font-size:1.05rem;">Eventos & Catering</span>
    <span style="color:rgba(15,13,11,0.35);">✦</span>
  </div>
</div>

<script>
  // Hero: entrada con stagger al cargar la página
  document.addEventListener('DOMContentLoaded', () => {
    const heroRevs = document.querySelectorAll('#inicio .reveal');
    heroRevs.forEach((el, i) => {
      setTimeout(() => el.classList.add('visible'), 350 + i * 220);
    });
  });
</script>
